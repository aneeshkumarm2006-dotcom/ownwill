# Copy to .env.local and fill in. Anything prefixed NEXT_PUBLIC_ is shipped to
# the browser — keep secrets WITHOUT that prefix.

# --- Public (exposed to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pro / B2B per-seat recurring price IDs (CAD monthly). Create three Stripe
# Products + Prices: pro_starter $79/seat (1-3), pro_team $69/seat (4-10),
# pro_enterprise custom (11+). Drop the price_... IDs below.
STRIPE_PRICE_PRO_STARTER=
STRIPE_PRICE_PRO_TEAM=
STRIPE_PRICE_PRO_ENTERPRISE=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=ca-central-1
SES_FROM_EMAIL=OwnWill <noreply@example.ca>
